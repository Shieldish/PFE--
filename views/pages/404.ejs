<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../layouts/head', { title: 'Erreur 404' }) %>
</head>
<body>
<div class="app-wrapper">
  <%- include('../layouts/sidebar') %>
  <div class="main-area" id="mainArea">
    <%- include('../layouts/navbar') %>
    <main class="page-content d-flex align-items-center justify-content-center" style="min-height:60vh;">
      <div class="text-center" style="max-width:480px;">
        <div style="font-size:5rem;color:var(--danger);font-weight:700;line-height:1;">404</div>
        <h4 class="mt-3 mb-2">Page introuvable</h4>
        <p class="text-muted mb-4">
          Oups ! La page que vous cherchez est actuellement indisponible.
        </p>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger mb-4"><strong>Détails :</strong> <%= error %></div>
        <% } %>
        <a href="/" class="btn btn-primary">
          <i class="bi bi-house me-2"></i>Retour à l'accueil
        </a>
      </div>
    </main>
    <%- include('../layouts/footer') %>
  </div>
</div>
<%- include('../layouts/scripts') %>
</body>
</html>
