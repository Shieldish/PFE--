<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../layouts/head', { title: 'Accueil' }) %>
</head>
<body>
<div class="app-wrapper">
  <%- include('../layouts/sidebar') %>
  <div class="main-area" id="mainArea">
    <%- include('../layouts/navbar') %>
    <main class="page-content">
      <h3 class="mb-3">Accueil</h3>
      <hr>

      <div class="container-fluid px-0">
        <form id="searchFilterForm" class="mb-4">
          <div class="row g-3">
            <div class="col-md-3">
              <input type="text" class="form-control" id="searchInput" placeholder="Rechercher des stages...">
            </div>
            <div class="col-md-2">
              <select class="form-select" id="domainFilter">
                <option value="">Tous les domaines</option>
              </select>
            </div>
            <div class="col-md-2">
              <select class="form-select" id="experienceFilter">
                <option value="">Tous les niveaux</option>
              </select>
            </div>
            <div class="col-md-2">
              <select class="form-select" id="stateFilter">
                <option value="">Toutes les villes</option>
              </select>
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i> Rechercher
              </button>
            </div>
          </div>
        </form>

        <div class="d-flex justify-content-end mb-3">
          <select class="form-select" id="sortSelect" style="width:auto;">
            <option value="dateDesc">Plus récents</option>
            <option value="dateAsc">Plus anciens</option>
            <option value="titleAsc">Titre A-Z</option>
            <option value="titleDesc">Titre Z-A</option>
          </select>
        </div>

        <div id="jobListings"></div>

        <nav aria-label="Pagination" class="mt-4">
          <ul class="pagination justify-content-center" id="pagination"></ul>
        </nav>
      </div>
    </main>
    <%- include('../layouts/footer') %>
  </div>
</div>
<%- include('../layouts/scripts') %>
<script>
$(document).ready(function() {
  let currentPage = 1;
  const groupsPerPage = 5;
  // Data injected server-side — no fetch needed
  let jobData = <%- JSON.stringify(stages) %>;
  let filteredJobData = [...jobData];

  populateFilters();
  updateJobListings();

  function populateFilters() {
    const domains     = [...new Set(jobData.map(j => j.Domaine))];
    const experiences = [...new Set(jobData.map(j => j.Niveau))];
    const states      = [...new Set(jobData.map(j => j.Address))];
    populateDropdown('#domainFilter',     domains,     'Tous les domaines');
    populateDropdown('#experienceFilter', experiences, 'Tous les niveaux');
    populateDropdown('#stateFilter',      states,      'Toutes les villes');
  }

  function populateDropdown(sel, opts, def) {
    const $d = $(sel).empty().append(`<option value="">${def}</option>`);
    opts.forEach(o => $d.append(`<option value="${o}">${o}</option>`));
  }

  function updateJobListings() {
    const $list = $('#jobListings').empty();
    const grouped = groupJobsByDomain(filteredJobData);
    const keys    = Object.keys(grouped);
    const start   = (currentPage - 1) * groupsPerPage;
    const end     = Math.min(start + groupsPerPage, keys.length);

    for (let i = start; i < end; i++) {
      const domain = keys[i];
      const jobs   = grouped[domain];
      const $sec   = $('<div class="mb-4">');
      $sec.append(`<hr><h5 class="text-primary mb-3"><a href="/search?q=${encodeURIComponent(domain)}">${domain}</a></h5>`);
      const $row = $('<div class="row g-3">');
      jobs.forEach(job => {
        const $col = $('<div class="col-md-4">');
        $col.append(createJobCard(job));
        $row.append($col);
      });
      $sec.append($row);
      $list.append($sec);
    }
    updatePagination(keys.length);
  }

  function groupJobsByDomain(jobs) {
    return jobs.reduce((acc, job) => {
      if (!acc[job.Domaine]) acc[job.Domaine] = [];
      acc[job.Domaine].push(job);
      return acc;
    }, {});
  }

  function createJobCard(job) {
    return $(`
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h6 class="card-title"><i class="bi bi-briefcase me-1"></i>${job.Titre}</h6>
          <p class="card-text text-muted small mb-1"><i class="bi bi-building me-1"></i>${job.Nom}</p>
          <p class="card-text text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>${job.Address}</p>
          <p class="card-text text-muted small mb-1"><i class="bi bi-calendar me-1"></i>${new Date(job.DateDebut).toLocaleDateString('fr-FR')} — ${new Date(job.DateFin).toLocaleDateString('fr-FR')}</p>
          <p class="card-text text-muted small mb-1"><i class="bi bi-person-workspace me-1"></i>${job.Experience} | ${job.Niveau}</p>
          <p class="card-text text-muted small mb-2"><i class="bi bi-people me-1"></i>${job.PostesVacants} poste(s)</p>
          <a href="/etudiant/postulate/${job.id}" class="btn btn-primary btn-sm mt-auto">
            <i class="bi bi-send me-1"></i>Postuler
          </a>
        </div>
      </div>`);
  }

  function updatePagination(total) {
    const totalPages = Math.ceil(total / groupsPerPage);
    const $pag = $('#pagination').empty();
    $pag.append(`<li class="page-item ${currentPage===1?'disabled':''}"><a class="page-link" href="#" aria-label="Précédent">&laquo;</a></li>`);
    for (let i = 1; i <= totalPages; i++) {
      if (i===1||i===totalPages||(i>=currentPage-2&&i<=currentPage+2)) {
        $pag.append(`<li class="page-item ${i===currentPage?'active':''}"><a class="page-link" href="#">${i}</a></li>`);
      } else if (i===currentPage-3||i===currentPage+3) {
        $pag.append(`<li class="page-item disabled"><a class="page-link" href="#">…</a></li>`);
      }
    }
    $pag.append(`<li class="page-item ${currentPage===totalPages?'disabled':''}"><a class="page-link" href="#" aria-label="Suivant">&raquo;</a></li>`);
  }

  $(document).on('click', '.pagination .page-link', function(e) {
    e.preventDefault();
    const $item = $(this).closest('.page-item');
    if ($item.hasClass('disabled')||$item.hasClass('active')) return;
    const label = $(this).attr('aria-label');
    if (label==='Précédent') currentPage--;
    else if (label==='Suivant') currentPage++;
    else currentPage = parseInt($(this).text());
    updateJobListings();
  });

  $('#searchFilterForm').on('submit', function(e) { e.preventDefault(); applyFilters(); });
  $('#sortSelect').on('change', applyFilters);

  function applyFilters() {
    const q   = $('#searchInput').val().toLowerCase();
    const dom = $('#domainFilter').val();
    const exp = $('#experienceFilter').val();
    const st  = $('#stateFilter').val();
    const srt = $('#sortSelect').val();
    const fields = ['Titre','Domaine','Experience','State','Address','Niveau','Libelle','Nom','Description'];
    filteredJobData = jobData.filter(job => {
      const match = fields.some(f => job[f] && job[f].toLowerCase().includes(q));
      return match && (!dom||job.Domaine===dom) && (!exp||job.Niveau===exp) && (!st||job.Address===st);
    });
    sortJobData(srt);
    currentPage = 1;
    updateJobListings();
  }

  function sortJobData(opt) {
    filteredJobData.sort((a,b) => {
      switch(opt) {
        case 'dateDesc': return new Date(b.DateDebut)-new Date(a.DateDebut);
        case 'dateAsc':  return new Date(a.DateDebut)-new Date(b.DateDebut);
        case 'titleAsc': return a.Titre.localeCompare(b.Titre);
        case 'titleDesc':return b.Titre.localeCompare(a.Titre);
        default: return 0;
      }
    });
  }

  updateJobListings();

  $(document).on('click', '.pagination .page-link', function(e) {
    e.preventDefault();
    const $item = $(this).closest('.page-item');
    if ($item.hasClass('disabled')||$item.hasClass('active')) return;
    const label = $(this).attr('aria-label');
    if (label==='Précédent') currentPage--;
    else if (label==='Suivant') currentPage++;
    else currentPage = parseInt($(this).text());
    updateJobListings();
  });

  $('#searchFilterForm').on('submit', function(e) { e.preventDefault(); applyFilters(); });
  $('#sortSelect').on('change', applyFilters);

  function applyFilters() {
    const q   = $('#searchInput').val().toLowerCase();
    const dom = $('#domainFilter').val();
    const exp = $('#experienceFilter').val();
    const st  = $('#stateFilter').val();
    const srt = $('#sortSelect').val();
    const fields = ['Titre','Domaine','Experience','State','Address','Niveau','Libelle','Nom','Description'];
    filteredJobData = jobData.filter(job => {
      const match = fields.some(f => job[f] && job[f].toLowerCase().includes(q));
      return match && (!dom||job.Domaine===dom) && (!exp||job.Niveau===exp) && (!st||job.Address===st);
    });
    sortJobData(srt);
    currentPage = 1;
    updateJobListings();
  }

  function sortJobData(opt) {
    filteredJobData.sort((a,b) => {
      switch(opt) {
        case 'dateDesc': return new Date(b.DateDebut)-new Date(a.DateDebut);
        case 'dateAsc':  return new Date(a.DateDebut)-new Date(b.DateDebut);
        case 'titleAsc': return a.Titre.localeCompare(b.Titre);
        case 'titleDesc':return b.Titre.localeCompare(a.Titre);
        default: return 0;
      }
    });
  }

});
</script>
</body>
</html>