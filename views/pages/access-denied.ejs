<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../layouts/head', { title: 'Accès refusé' }) %>
</head>
<body>
<div class="app-wrapper">
  <%- include('../layouts/sidebar') %>
  <div class="main-area" id="mainArea">
    <%- include('../layouts/navbar') %>
    <main class="page-content d-flex align-items-center justify-content-center" style="min-height:60vh;">
      <div class="text-center" style="max-width:480px;">
        <div style="font-size:4rem;color:var(--warning);"><i class="bi bi-shield-exclamation"></i></div>
        <h4 class="mt-3 mb-2">Accès refusé</h4>
        <p class="text-muted mb-4">Vous n'avez pas les permissions nécessaires pour accéder à cette page.</p>

        <% if (messages && messages.error) { %>
          <div class="alert alert-danger mb-3"><%= messages.error %></div>
        <% } %>
        <% if (messages && messages.success) { %>
          <div class="alert alert-success mb-3"><%= messages.success %></div>
        <% } %>
        <% if (messages && messages.info) { %>
          <div class="alert alert-warning mb-3"><%= messages.info %></div>
        <% } %>

        <a href="/" class="btn btn-primary">
          <i class="bi bi-house me-2"></i>Retour à l'accueil
        </a>
      </div>
    </main>
    <%- include('../layouts/footer') %>
  </div>
</div>
<%- include('../layouts/scripts') %>
</body>
</html>
