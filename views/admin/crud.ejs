<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../layouts/head', { title: 'Table — ' + (tableName ? tableName.toUpperCase() : '') }) %>
  <%- include('./crud-header') %>
  <style>
    .table-responsive { overflow-x: auto; overflow-y: auto; }
    th, td { border: 1px solid var(--border); padding: 8px; max-width: 200px; word-wrap: break-word; }
    .modal-dialog { width: auto; min-width: 30%; margin: 1rem auto; }
  </style>
</head>
<body>
<div class="app-wrapper">
  <%- include('../layouts/sidebar') %>
  <div class="main-area" id="mainArea">
    <%- include('../layouts/navbar') %>
    <main class="page-content">
      <%- include('../shared/flash-messages') %>

      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <a href="/gestion" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-arrow-left"></i> Retour
        </a>
        <span class="badge badge-warning" style="background:var(--warning);color:#fff;padding:6px 12px;border-radius:var(--radius);">
          <strong><%= tableName.toUpperCase() %> : <%= count %> entrée(s)</strong>
        </span>
        <% if (tableName) { %>
          <button type="button" class="btn btn-outline-success btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="fas fa-plus"></i> Ajouter un <%= tableName %>
          </button>
        <% } %>
      </div>

      <% if (data.length > 0) { %>
        <div class="mb-3">
          <input type="text" id="searchInput" class="form-control" placeholder="Rechercher...">
        </div>
        <div class="table-responsive">
          <table class="table table-hover table-striped searchable sortable">
            <thead>
              <tr>
                <% Object.keys(data[0]).forEach(key => { %>
                  <th class="text-center"><%= key %></th>
                <% }); %>
                <th>Voir</th><th>Éditer</th><th>Supprimer</th>
              </tr>
            </thead>
            <tbody id="tableBody">
              <% data.forEach(row => { %>
                <tr>
                  <% Object.values(row).forEach(value => { %>
                    <td class="text-center"><%= value %></td>
                  <% }); %>
                  <td>
                    <button type="button" class="btn btn-outline-warning btn-sm" data-bs-toggle="modal"
                      data-bs-target="#viewsModal<%= row.EMAIL.replace(/[@.]/g,'_') %>">
                      <i class="fas fa-eye"></i>
                    </button>
                    <div class="modal fade" id="viewsModal<%= row.EMAIL.replace(/[@.]/g,'_') %>" tabindex="-1" aria-hidden="true">
                      <div class="modal-dialog modal-sm">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title">Détails : <%= row.EMAIL %></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                          </div>
                          <div class="modal-body">
                            <table class="table table-bordered table-sm">
                              <% Object.keys(row).forEach(key => { %>
                                <tr><th><%= key %></th><td><%= row[key] %></td></tr>
                              <% }); %>
                            </table>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Fermer</button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                      data-bs-target="#editModal<%= row.EMAIL.replace(/[@.]/g,'_') %>">
                      <i class="fas fa-edit"></i>
                    </button>
                  </td>
                  <td>
                    <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                      data-bs-target="#deleteModal<%= row.EMAIL.replace(/[@.]/g,'_') %>">
                      <i class="fas fa-trash"></i>
                    </button>
                    <div class="modal fade" id="deleteModal<%= row.EMAIL.replace(/[@.]/g,'_') %>" tabindex="-1" aria-hidden="true">
                      <div class="modal-dialog modal-sm">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title">Confirmation</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                          </div>
                          <div class="modal-body text-center">
                            Supprimer définitivement <strong class="text-primary"><%= row.EMAIL %></strong> de <em><%= tableName %></em> ?
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
                            <a href="/gestion/<%= tableName %>/delete/<%= row.EMAIL %>" class="btn btn-danger btn-sm">Supprimer</a>
                          </div>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="alert alert-warning text-center">
          <strong><%= tableName.toUpperCase() %></strong> ne contient aucune donnée.
        </div>
      <% } %>
    </main>
    <%- include('../layouts/footer') %>
  </div>
</div>
<%- include('./crud-modals') %>
<%- include('../layouts/scripts') %>
<script>
$(document).ready(function() {
  $('#searchInput').on('keyup', function() {
    const val = $(this).val().toLowerCase();
    $('#tableBody tr').filter(function() {
      $(this).toggle($(this).text().toLowerCase().indexOf(val) > -1);
    });
  });
});
</script>
</body>
</html>
